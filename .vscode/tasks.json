{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "manual: rebuild data.json",
      "type": "shell",
      "command": "python",
      "args": ["action/dashboard/build_data.py"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "close": true }
    },
    {
      "label": "manual: sync action/ to review/",
      "type": "shell",
      "command": "python",
      "args": ["review/scripts/sync-from-action.py"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "close": true }
    },
    {
      "label": "manual: start review server",
      "type": "shell",
      "command": "python",
      "args": ["action/dashboard/review_server.py", "--port", "8080", "--host", "127.0.0.1"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "isBackground": true,
      "presentation": { "reveal": "never", "close": true }
    },
    {
      "label": "manual: start review server (with tunnel)",
      "type": "shell",
      "command": "python",
      "args": ["action/dashboard/review_server.py", "--port", "8080", "--host", "0.0.0.0", "--tunnel"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "isBackground": true,
      "presentation": { "reveal": "never", "close": true }
    }
  ]
}
