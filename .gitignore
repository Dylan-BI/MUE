Thumbs.db
.DS_Store
*.log
__pycache__/
*.pyc

# Generated by build_data.py — CI regenerates this during deploy
action/dashboard/data.json

# ── Dummy Learner Proxy test data ──────────────────────────────────────
# The proxy generates test artifacts into these directories as a stand-in
# for the real learner workflow. Exclude all proxy-generated content while
# preserving .gitkeep files so the folder hierarchy stays in version control.
# Remove these rules when the real learner interface is active.
action/learner_config.json
action/notes/*
!action/notes/.gitkeep
action/evidence/*
!action/evidence/.gitkeep
action/reports/*
!action/reports/.gitkeep
action/archive/notes/*
!action/archive/notes/.gitkeep
action/archive/evidence/*
!action/archive/evidence/.gitkeep
action/archive/reports/*
!action/archive/reports/.gitkeep
action/archive/*.md