{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MUE Dashboard Data Schema",
  "description": "Schema for action/dashboard/data.json generated by build_data.py",
  "type": "object",
  "required": ["generated", "version", "notes", "evidence", "reports", "artifacts", "scripts", "dashboard", "review", "source", "summary"],
  "properties": {
    "generated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when data.json was generated"
    },
    "version": {
      "type": "object",
      "required": ["commit", "timestamp"],
      "properties": {
        "commit": { "type": "string", "description": "Git commit hash" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Commit timestamp" }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "filename", "date", "day_number", "classification", "primary_track", "level", "week_number", "required_artifact", "what_learned", "evidence_produced", "what_remains", "next_step", "scorecard", "codex_gate", "category_tags"],
        "properties": {
          "id": { "type": "string" },
          "filename": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "day_number": { "type": "integer", "minimum": 1, "maximum": 28 },
          "classification": { "type": "string", "enum": ["Foundational", "Developing", "Operational", "Ready For Codex Acceleration"] },
          "primary_track": { "type": "string", "enum": ["Pyramid operations", "Codex productivity", "BI judgment"] },
          "level": { "type": "integer", "minimum": 1, "maximum": 4 },
          "week_number": { "type": "integer", "minimum": 1, "maximum": 4 },
          "required_artifact": { "type": "string" },
          "what_learned": { "type": "string" },
          "evidence_produced": { "type": "string" },
          "what_remains": { "type": "string" },
          "next_step": { "type": "string" },
          "scorecard": {
            "type": "object",
            "patternProperties": {
              "^[a-z_]+$": { "type": "string", "enum": ["Pass", "Moderate", "Fail", "Unscored"] }
            }
          },
          "codex_gate": {
            "type": "object",
            "patternProperties": {
              "^[a-z_]+$": { "type": "string", "enum": ["Yes", "No"] }
            }
          },
          "category_tags": { "type": "string" }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "filename", "folder", "size", "modified", "preview", "content", "is_markdown", "is_text", "page_category", "action_cat", "was_changed"],
        "properties": {
          "path": { "type": "string" },
          "filename": { "type": "string" },
          "folder": { "type": "string" },
          "size": { "type": "integer", "minimum": 0 },
          "modified": { "type": "string", "format": "date-time" },
          "preview": { "type": ["string", "null"] },
          "content": { "type": ["string", "null"] },
          "is_markdown": { "type": "boolean" },
          "is_text": { "type": "boolean" },
          "page_category": { "type": "string" },
          "action_cat": { "type": "string" },
          "was_changed": { "type": "boolean" }
        }
      }
    },
    "reports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "filename", "folder", "size", "modified", "preview", "content", "is_markdown", "is_text", "page_category", "action_cat", "was_changed"],
        "properties": {
          "path": { "type": "string" },
          "filename": { "type": "string" },
          "folder": { "type": "string" },
          "size": { "type": "integer", "minimum": 0 },
          "modified": { "type": "string", "format": "date-time" },
          "preview": { "type": ["string", "null"] },
          "content": { "type": ["string", "null"] },
          "is_markdown": { "type": "boolean" },
          "is_text": { "type": "boolean" },
          "page_category": { "type": "string" },
          "action_cat": { "type": "string" },
          "was_changed": { "type": "boolean" }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["notes", "evidence", "reports", "templates", "scripts", "dashboard", "review", "source"],
      "properties": {
        "notes": { "type": "array", "items": { "type": "object" } },
        "evidence": { "type": "array", "items": { "type": "object" } },
        "reports": { "type": "array", "items": { "type": "object" } },
        "templates": { "type": "array", "items": { "type": "object" } },
        "scripts": { "type": "array", "items": { "type": "object" } },
        "dashboard": { "type": "array", "items": { "type": "object" } },
        "review": { "type": "array", "items": { "type": "object" } },
        "source": { "type": "array", "items": { "type": "object" } }
      }
    },
    "scripts": { "type": "array", "items": { "type": "object" } },
    "dashboard": { "type": "array", "items": { "type": "object" } },
    "review": { "type": "array", "items": { "type": "object" } },
    "source": { "type": "array", "items": { "type": "object" } },
    "summary": {
      "type": "object",
      "required": ["total_days", "working_days_elapsed", "calendar_status", "level_progression", "scorecard_trend", "proof_tasks", "codex_gate_status", "classification_trend", "track_distribution", "category_coverage", "evidence_count", "report_count"],
      "properties": {
        "total_days": { "type": "integer", "minimum": 0 },
        "working_days_elapsed": { "type": "integer", "minimum": 0 },
        "calendar_status": { "type": "string" },
        "level_progression": {
          "type": "object",
          "required": ["current_level", "overall_start_date", "levels"],
          "properties": {
            "current_level": { "type": "integer", "minimum": 1, "maximum": 4 },
            "overall_start_date": { "type": ["string", "null"], "format": "date" },
            "levels": {
              "type": "object",
              "patternProperties": {
                "^[1-4]$": {
                  "type": "object",
                  "required": ["start_date", "completion_date", "days_completed", "days_required", "is_unlocked", "is_completed", "in_progress"],
                  "properties": {
                    "start_date": { "type": ["string", "null"], "format": "date" },
                    "completion_date": { "type": ["string", "null"], "format": "date" },
                    "days_completed": { "type": "integer", "minimum": 0 },
                    "days_required": { "type": "integer", "const": 28 },
                    "is_unlocked": { "type": "boolean" },
                    "is_completed": { "type": "boolean" },
                    "in_progress": { "type": "boolean" }
                  }
                }
              }
            }
          }
        },
        "scorecard_trend": {
          "type": "object",
          "patternProperties": {
            "^[a-z_]+$": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["date", "score"],
                "properties": {
                  "date": { "type": "string", "format": "date" },
                  "score": { "type": "string", "enum": ["Pass", "Moderate", "Fail", "Unscored"] }
                }
              }
            }
          }
        },
        "proof_tasks": {
          "type": "object",
          "patternProperties": {
            "^PT[1-6]$": { "type": "boolean" }
          }
        },
        "codex_gate_status": {
          "type": "object",
          "patternProperties": {
            "^[a-z_]+$": { "type": "string", "enum": ["Yes", "No"] }
          }
        },
        "classification_trend": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "classification"],
            "properties": {
              "date": { "type": "string", "format": "date" },
              "classification": { "type": "string" }
            }
          }
        },
        "track_distribution": {
          "type": "object",
          "patternProperties": {
            "^[a-z ]+$": { "type": "integer", "minimum": 0 }
          }
        },
        "category_coverage": {
          "type": "object",
          "patternProperties": {
            "^[a-z-]+$": { "type": "integer", "minimum": 0 }
          }
        },
        "evidence_count": { "type": "integer", "minimum": 0 },
        "report_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}