{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MUE Dashboard Data Schema",
  "description": "Schema for action/dashboard/data.json generated by build_data.py",
  "type": "object",
  "required": ["generated", "version", "notes", "evidence", "reports", "artifacts", "page_artifacts", "changed_files", "changes_by_page", "all_file_changes", "change_counts", "source_criteria", "review_data", "synced_reviews", "summary", "categories", "source_category_map", "levels", "level_categories", "environment_status"],
  "properties": {
    "generated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when data.json was generated"
    },
    "version": {
      "type": "object",
      "required": ["commit", "timestamp"],
      "properties": {
        "commit": { "type": "string", "description": "Git commit hash" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Commit timestamp" }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "filename", "date", "day_number", "classification", "primary_track", "level", "week_number", "required_artifact", "what_learned", "evidence_produced", "what_remains", "next_step", "scorecard", "codex_gate"],
        "properties": {
          "id": { "type": "string" },
          "filename": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "day_number": { "type": "integer", "minimum": 1, "maximum": 28 },
          "classification": { "type": "string", "enum": ["Foundational", "Developing", "Operational", "Ready For Codex Acceleration"] },
          "primary_track": { "type": "string", "enum": ["Pyramid operations", "Codex productivity", "BI judgment"] },
          "level": { "type": "integer", "minimum": 1, "maximum": 4 },
          "week_number": { "type": ["integer", "null"], "minimum": 1, "maximum": 4 },
          "required_artifact": { "type": "string" },
          "what_learned": { "type": "string" },
          "evidence_produced": { "type": "string" },
          "what_remains": { "type": "string" },
          "next_step": { "type": "string" },
          "scorecard": {
            "type": "object",
            "patternProperties": {
              "^[a-z_]+$": { "type": "string", "enum": ["Pass", "Moderate", "Fail", "Unscored"] }
            }
          },
          "codex_gate": {
            "type": "object",
            "patternProperties": {
              "^[a-z_]+$": { "type": "string", "enum": ["Yes", "No"] }
            }
          },
          "category_tags": { "type": ["string", "null"] }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "size", "modified"],
        "properties": {
          "path": { "type": "string" },
          "filename": { "type": "string" },
          "folder": { "type": "string" },
          "size": { "type": "integer", "minimum": 0 },
          "modified": { "type": "string", "format": "date-time" },
          "preview": { "type": ["string", "null"] },
          "content": { "type": ["string", "null"] },
          "is_markdown": { "type": "boolean" },
          "is_text": { "type": "boolean" },
          "page_category": { "type": "string" },
          "action_cat": { "type": "string" },
          "was_changed": { "type": "boolean" }
        }
      }
    },
    "reports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "size", "modified"],
        "properties": {
          "path": { "type": "string" },
          "filename": { "type": ["string", "null"] },
          "folder": { "type": ["string", "null"] },
          "size": { "type": "integer", "minimum": 0 },
          "modified": { "type": ["string", "null"], "format": "date-time" },
          "preview": { "type": ["string", "null"] },
          "content": { "type": ["string", "null"] },
          "is_markdown": { "type": ["boolean", "null"] },
          "is_text": { "type": ["boolean", "null"] },
          "page_category": { "type": ["string", "null"] },
          "action_cat": { "type": ["string", "null"] },
          "was_changed": { "type": ["boolean", "null"] }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["notes", "evidence", "reports", "templates", "scripts", "dashboard", "other"],
      "properties": {
        "notes": { "type": "array", "items": { "type": "object" } },
        "evidence": { "type": "array", "items": { "type": "object" } },
        "reports": { "type": "array", "items": { "type": "object" } },
        "templates": { "type": "array", "items": { "type": "object" } },
        "scripts": { "type": "array", "items": { "type": "object" } },
        "dashboard": { "type": "array", "items": { "type": "object" } },
        "other": { "type": "array", "items": { "type": "object" } }
      }
    },
    "scripts": { "type": "array", "items": { "type": "object" } },
    "dashboard": { "type": "array", "items": { "type": "object" } },
    "review": { "type": "array", "items": { "type": "object" } },
    "source": { "type": "array", "items": { "type": "object" } },
    "summary": {
      "type": "object",
      "required": ["total_days", "unique_weeks", "latest_classification", "classification_sequence", "days_per_week", "evidence_count", "scorecard_trend", "codex_gate_status", "completed_tracks", "proof_tasks", "current_week", "curriculum_start_date", "curriculum_start_source", "curriculum_current_day", "calendar_days_elapsed", "working_days_elapsed", "calendar_status", "week_progress", "learner_level", "level_progression", "earliest_artifact_date", "today"],
      "properties": {
        "total_days": { "type": "integer", "minimum": 0 },
        "unique_weeks": { "type": "integer", "minimum": 0 },
        "latest_classification": { "type": "string" },
        "classification_sequence": { "type": "array", "items": { "type": "object" } },
        "days_per_week": { "type": "object" },
        "evidence_count": { "type": "integer", "minimum": 0 },
        "scorecard_trend": {
          "type": "object",
          "patternProperties": {
            "^[a-z_]+$": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["day", "score"],
                "properties": {
                  "day": { "type": "integer" },
                  "score": { "type": "string", "enum": ["Pass", "Moderate", "Fail", "Unscored"] }
                }
              }
            }
          }
        },
        "codex_gate_status": {
          "type": "object",
          "patternProperties": {
            "^[a-z_]+$": { "type": "string", "enum": ["Yes", "No"] }
          }
        },
        "completed_tracks": { "type": "object" },
        "proof_tasks": {
          "type": "object",
          "patternProperties": {
            "^PT[1-6]$": {
              "type": "object",
              "required": ["id", "description", "found", "days"],
              "properties": {
                "id": { "type": "string" },
                "description": { "type": "string" },
                "found": { "type": "boolean" },
                "days": { "type": "array", "items": { "type": "integer" } }
              }
            }
          }
        },
        "current_week": { "type": "integer", "minimum": 1 },
        "curriculum_start_date": { "type": ["string", "null"], "format": "date" },
        "curriculum_start_source": { "type": "string" },
        "curriculum_current_day": { "type": "integer", "minimum": 0 },
        "calendar_days_elapsed": { "type": "integer", "minimum": 0 },
        "working_days_elapsed": { "type": "integer", "minimum": 0 },
        "calendar_status": { "type": "string", "enum": ["on_track", "behind", "no_data", "ahead"] },
        "week_progress": { "type": ["object", "array"] },
        "learner_level": { "type": "integer", "minimum": 1, "maximum": 4 },
        "level_progression": {
          "type": "object",
          "required": ["current_level", "overall_start_date", "levels"],
          "properties": {
            "current_level": { "type": "integer", "minimum": 1, "maximum": 4 },
            "overall_start_date": { "type": ["string", "null"], "format": "date" },
            "levels": {
              "type": "object",
              "patternProperties": {
                "^[1-4]$": {
                  "type": "object",
                  "required": ["start_date", "completion_date", "days_completed", "days_required", "is_unlocked", "is_completed", "in_progress"],
                  "properties": {
                    "start_date": { "type": ["string", "null"], "format": "date" },
                    "completion_date": { "type": ["string", "null"], "format": "date" },
                    "days_completed": { "type": "integer", "minimum": 0 },
                    "days_required": { "type": "integer", "minimum": 28 },
                    "is_unlocked": { "type": "boolean" },
                    "is_completed": { "type": "boolean" },
                    "in_progress": { "type": "boolean" }
                  }
                }
              }
            }
          }
        },
        "earliest_artifact_date": { "type": ["string", "null"], "format": "date" },
        "today": { "type": "string", "format": "date" }
      }
    },
    "categories": { "type": "object" },
    "source_category_map": { "type": "object" },
    "levels": { "type": "object" },
    "level_categories": { "type": "object" },
    "environment_status": {
      "type": "object",
      "required": ["checked_at", "overall_status", "requirements"],
      "properties": {
        "checked_at": { "type": "string", "format": "date-time" },
        "overall_status": { "type": "string", "enum": ["ready", "partial", "not_ready", "unknown", "adequate"] },
        "requirements": { "type": "object" }
      }
    }
  }
}