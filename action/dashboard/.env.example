# MUE Review Server — SMTP Configuration
# Copy this file to .env and fill in your credentials.
# The server reads .env automatically on startup.
#
# Gmail:    smtp.gmail.com / port 587 / requires App Password
#           Get one at: https://myaccount.google.com/security → App passwords
# Outlook:  smtp.office365.com / port 587
# Local:    localhost / port 25 (no auth)

MUE_SMTP_HOST=smtp.gmail.com
MUE_SMTP_PORT=587
MUE_SMTP_USER=your-email@gmail.com
MUE_SMTP_PASS=your-16-char-app-password
MUE_SMTP_FROM=your-email@gmail.com
MUE_SMTP_TLS=true

# Daily summary schedule (24h format)
MUE_SUMMARY_HOUR=17
MUE_SUMMARY_MINUTE=0

# Admin email — receives all reviewer input (daily summaries + individual reviews)
MUE_ADMIN_EMAIL=dylan@bicyclebi.com
