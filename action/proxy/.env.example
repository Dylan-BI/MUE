# MUE Learner Web Interface — Email Configuration
# Copy this file to .env and fill in your values.
# Environment variables take precedence over .env values.

# SMTP Server
# Gmail:   smtp.gmail.com:587
# Outlook: smtp.office365.com:587
# Local:   localhost:25 (no auth needed)
MUE_SMTP_HOST=smtp.gmail.com
MUE_SMTP_PORT=587
MUE_SMTP_USER=your-email@gmail.com
MUE_SMTP_PASS=your-app-password
MUE_SMTP_FROM=your-email@gmail.com
MUE_SMTP_TLS=true

# Learner email (where daily summaries are sent)
MUE_LEARNER_EMAIL=learner@example.com

# Daily summary schedule (24h format)
MUE_SUMMARY_HOUR=6
MUE_SUMMARY_MINUTE=0

# Enable daily summary (set to true to activate)
MUE_LEARNER_SUMMARY=false

# Tunnel notification email — receives public tunnel URLs when --tunnel is used
# Defaults to MUE_SMTP_USER if not set
MUE_TUNNEL_NOTIFY_EMAIL=monteretroion@gmail.com
